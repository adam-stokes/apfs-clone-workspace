#!/bin/bash
# apfs-clone: Git-aware APFS copy-on-write clone
# Only clones tracked files + .git directory — skips all untracked bloat
#
# Usage: apfs-clone <source-repo> [target-path]
#
# If target-path is omitted, clones to ~/.apfs-clones/<repo-name>-<pid>

set -euo pipefail

SRC="${1:?Usage: apfs-clone <source-repo> [target-path]}"

# Resolve source to absolute path
SRC="$(cd "$SRC" && pwd)"
REPO_NAME="$(basename "$SRC")"

# Default target: ~/.apfs-clones/<repo>-<pid> (APFS volume, not /tmp)
CLONE_BASE="${APFS_CLONE_DIR:-$HOME/.apfs-clones}"
DST="${2:-$CLONE_BASE/$REPO_NAME-$$}"

if [ -d "$DST" ]; then
  echo "error: target already exists: $DST" >&2
  exit 1
fi

if [ ! -d "$SRC/.git" ]; then
  echo "error: not a git repository: $SRC" >&2
  exit 1
fi

mkdir -p "$DST"

# Verify APFS support on target volume
TEST_SRC="$DST/.apfs-test-src-$$"
TEST_DST="$DST/.apfs-test-dst-$$"
echo "test" > "$TEST_SRC"
if cp -c "$TEST_SRC" "$TEST_DST" 2>/dev/null; then
  CP_FLAG="-c"
else
  echo "warning: APFS clones not supported at $DST, falling back to regular copy" >&2
  CP_FLAG=""
fi
rm -f "$TEST_SRC" "$TEST_DST"

# 1. Clone .git directory (APFS CoW — preserves full history)
echo "cloning .git..."
cp $CP_FLAG -R "$SRC/.git" "$DST/.git"

# 2. Create directory structure for all tracked files
echo "creating directory structure..."
git -C "$SRC" ls-files | xargs -n1 dirname | sort -u | while IFS= read -r dir; do
  mkdir -p "$DST/$dir"
done

# 3. Clone tracked files with APFS CoW in parallel
echo "cloning tracked files..."
FILE_COUNT=$(git -C "$SRC" ls-files | wc -l | tr -d ' ')
git -C "$SRC" ls-files -z | xargs -0 -P 8 -I {} cp $CP_FLAG "$SRC/{}" "$DST/{}"

# 4. Reset index to match working tree (clone starts clean)
git -C "$DST" reset --quiet HEAD 2>/dev/null || true

echo "done: $FILE_COUNT tracked files cloned to $DST"
